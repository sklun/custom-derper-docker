# DERP Server Configuration
# ========================

# Timezone
TZ=Asia/Shanghai

# DERP Domain/IP (required - replace with your domain or IP)
DERP_DOMAIN=

# Listen Address
DERP_ADDR=:443

# HTTP Port (-1 to disable)
DERP_HTTP_PORT=-1

# Certificate Mode (manual, letsencrypt)
DERP_CERT_MODE=manual

# Certificate Directory
DERP_CERT_DIR=/app/certs

# Enable STUN
DERP_STUN=true

# STUN Port
DERP_STUN_PORT=3478

# Verify Clients (only allow Tailscale authorized nodes)
DERP_VERIFY_CLIENTS=true

# Verify Client URL (empty to disable)
DERP_VERIFY_CLIENT_URL=
